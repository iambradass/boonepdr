{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Edit",
          "file_paths": ["src/**/*.tsx", "src/**/*.ts", "src/**/*.css"]
        },
        "command": ".claude/scripts/codex-review.sh \"$CLAUDE_FILE_PATH\""
      },
      {
        "matcher": {
          "tool_name": "Write",
          "file_paths": ["src/**/*.tsx", "src/**/*.ts", "src/**/*.css"]
        },
        "command": ".claude/scripts/codex-review.sh \"$CLAUDE_FILE_PATH\""
      }
    ]
  }
}
